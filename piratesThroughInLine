avascript:(function(){const links=document.querySelectorAll("a[href]");let matches=[];links.forEach(link=>{const href=link.href||link.getAttribute("href");if(href&&href.includes("https://thepiratebay.org/description.php?id=")){matches.push(href)}});const div=document.createElement('div');div.id='tpb-links';div.style.cssText='position:fixed;top:10px;right:10px;background:#1a1a1a;color:#fff;padding:20px;border-radius:10px;z-index:999999;max-width:500px;max-height:80vh;overflow:auto;font-family:Segoe UI,sans-serif;font-size:12px;border:2px solid #00ff00;box-shadow:0 0 30px rgba(0,255,0,0.2);min-width:300px;';div.innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;border-bottom:2px solid #00ff00;padding-bottom:10px;"><h3 style="margin:0;color:#fff;">🔗 Links (<span style="color:#00ff00;">'+matches.length+'</span>)</h3><div><button onclick="copyLinks()" style="background:#00ff00;color:#000;border:none;padding:5px 15px;border-radius:5px;cursor:pointer;font-weight:bold;font-size:14px;margin-right:8px;">📋 Copy</button><button onclick="closeDiv()" style="background:#ff4444;color:#fff;border:none;padding:5px 15px;border-radius:5px;cursor:pointer;font-weight:bold;font-size:14px;">✕ Close</button></div></div><pre id="tpb-links-content" style="white-space:pre-wrap;word-break:break-all;margin:0;font-family:monospace;font-size:12px;color:#00ff00;">'+(matches.length>0?matches.join("\n"):"No links found")+'</pre>';document.body.appendChild(div);window.copyLinks=function(){const links=document.getElementById('tpb-links-content').textContent;navigator.clipboard.writeText(links).then(()=>{const btn=document.querySelector('[onclick="copyLinks()"]');const origText=btn.textContent;btn.textContent="✅ Copied!";btn.style.background="#ff8800";btn.style.color="#fff";setTimeout(()=>{btn.textContent=origText;btn.style.background="#00ff00";btn.style.color="#000"},1500)}).catch(()=>{alert("Failed to copy.")})};window.closeDiv=function(){const div=document.getElementById('tpb-links');if(div)document.body.removeChild(div)}})();